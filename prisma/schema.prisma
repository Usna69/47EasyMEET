generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Meeting {
  id               String            @id @default(cuid())
  title            String
  description      String
  date             DateTime
  location         String
  creatorEmail     String?
  sector           String?
  creatorType      String?
  meetingId        String?
  meetingType      String            @default("PHYSICAL")
  onlineMeetingUrl String?
  registrationEnd  DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customLetterhead String?
  meetingCategory  String?
  organization     String?
  password         String?
  attendees        Attendee[]
  resources        MeetingResource[]
}

model Attendee {
  id            String   @id @default(cuid())
  meetingId     String
  name          String
  email         String
  organization  String?
  designation   String
  signatureData String?
  phoneNumber   String?
  createdAt     DateTime @default(now())
  meeting       Meeting  @relation(fields: [meetingId], references: [id])
}

model MeetingResource {
  id          String   @id @default(cuid())
  meetingId   String
  fileName    String
  fileType    String
  fileSize    Int
  fileUrl     String
  description String?
  uploadedAt  DateTime @default(now())
  meeting     Meeting  @relation(fields: [meetingId], references: [id])
}

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  name                     String
  password                 String
  role                     String    @default("ADMIN")
  department               String?
  designation              String?
  passwordResetRequested   Boolean   @default(false)
  passwordResetRequestedAt DateTime?
  isFirstLogin             Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  customLetterhead         String?   @default("defaultlh.jpg")
  swgLetterhead            String?   @default("swg.jpg")
  userLetterhead           String?   @default("defaultlh.jpg")
  passwordResetToken       String?   @unique
  passwordResetTokenExpiry DateTime?
}
